# ─── HireForge Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# Real API keys must NEVER be committed to version control.

# ── LLM Providers (configure at least one) ─────────────────────────────────

# OpenAI — required for voice/TTS and Whisper transcription features
OPENAI_API_KEY=sk-...

# OpenRouter — access to 200+ models (Claude, Mistral, Llama, etc.)
OPENROUTER_API_KEY=sk-or-...

# Ollama — local LLM running on your machine (no API key needed)
# Set this if Ollama is not on localhost
OLLAMA_API_BASE=http://localhost:11434

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./hireforge.db

# ── Frontend ────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api

# ── Optional ────────────────────────────────────────────────────────────────
# Path to LinkedIn automation scripts (auto-apply feature)
HIREFORGE_SCRIPTS_DIR=./scripts
